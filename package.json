 {
  "name": "qq-farm-bot-ui",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev:core": "pnpm -C core dev",
    "dev:web": "pnpm -C web dev",
    "dev": "pnpm build:web && pnpm dev:core",
    "lint": "pnpm lint:core && pnpm lint:web",
    "lint:core": "pnpm -C core lint",
    "lint:web": "pnpm -C web lint",
    "build:web": "pnpm -C web build",
    "build": "pnpm build:web",
    "package:win": "pnpm build:web && pnpm -C core build:win",
    "package:linux": "pnpm build:web && pnpm -C core build:linux",
    "package:mac": "pnpm build:web && pnpm -C core build:mac",
    "package:release": "pnpm build:web && pnpm -C core build:release",
    "install:all": "pnpm install -r"
  },
  "pnpm": {
    "overrides": {
      "@babel/traverse": "7.26.10",
      "axios": "1.18.1",
      "express": "4.22.2",
      "form-data": "4.0.6",
      "lodash": "4.18.1",
      "path-to-regexp": "0.1.13",
      "picomatch": "4.0.4",
      "postcss": "8.5.15",
      "protobufjs": "8.6.5",
      "qs": "6.15.3",
      "socket.io-parser": "4.2.6",
      "ws": "8.21.0",
      "yaml": "2.9.0"
    }
  }
}
